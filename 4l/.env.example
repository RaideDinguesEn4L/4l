# Configuration environnement (optionnel)
# Copiez ce fichier en .env.local pour vos variables d'environnement

# Formulaire de contact (optionnel - pour intégration future)
# NEXT_PUBLIC_CONTACT_EMAIL=votre@email.com

# Analytics (optionnel)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Réseaux sociaux (déjà dans le code, mais peut être centralisé ici)
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/votre_compte
# NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/votre_page
# NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/votre_profil
